#!/usr/bin/env python3
"""Catppuccin Mocha analog clock screensaver."""

import math
import random
import sys
from datetime import datetime

import pygame

# Catppuccin Mocha palette
BG       = ( 30,  30,  46)  # #1e1e2e
SURFACE0 = ( 49,  50,  68)  # #313244
OVERLAY0 = (108, 112, 134)  # #6c7086
TEXT     = (205, 214, 244)  # #cdd6f4
BLUE     = (137, 180, 250)  # #89b4fa
MAUVE    = (203, 166, 247)  # #cba6f7
PINK     = (245, 194, 231)  # #f5c2e7
PEACH    = (250, 179, 135)  # #fab387


def draw_clock(surface, cx, cy, radius, now):
    # Face
    pygame.draw.circle(surface, SURFACE0, (cx, cy), radius)
    pygame.draw.circle(surface, OVERLAY0, (cx, cy), radius, 2)

    # Hour marks
    for i in range(12):
        angle = math.radians(i * 30 - 90)
        outer = radius - 8
        inner = radius - 20 if i % 3 == 0 else radius - 14
        width = 3 if i % 3 == 0 else 1
        x1 = cx + math.cos(angle) * outer
        y1 = cy + math.sin(angle) * outer
        x2 = cx + math.cos(angle) * inner
        y2 = cy + math.sin(angle) * inner
        pygame.draw.line(surface, TEXT, (int(x1), int(y1)), (int(x2), int(y2)), width)

    h = now.hour % 12
    m = now.minute
    s = now.second + now.microsecond / 1_000_000

    # Hour hand
    angle = math.radians((h + m / 60) * 30 - 90)
    hlen = radius * 0.5
    pygame.draw.line(surface, MAUVE, (cx, cy),
                     (int(cx + math.cos(angle) * hlen), int(cy + math.sin(angle) * hlen)), 5)

    # Minute hand
    angle = math.radians((m + s / 60) * 6 - 90)
    mlen = radius * 0.72
    pygame.draw.line(surface, BLUE, (cx, cy),
                     (int(cx + math.cos(angle) * mlen), int(cy + math.sin(angle) * mlen)), 3)

    # Second hand
    angle = math.radians(s * 6 - 90)
    slen = radius * 0.85
    pygame.draw.line(surface, PINK, (cx, cy),
                     (int(cx + math.cos(angle) * slen), int(cy + math.sin(angle) * slen)), 1)

    # Centre dot
    pygame.draw.circle(surface, PEACH, (cx, cy), 6)


def main():
    pygame.init()
    info = pygame.display.Info()
    W, H = info.current_w, info.current_h
    screen = pygame.display.set_mode((W, H), pygame.FULLSCREEN | pygame.NOFRAME)
    pygame.mouse.set_visible(False)

    clock = pygame.time.Clock()
    font = pygame.font.SysFont("monospace", 36)

    radius = min(W, H) // 3
    margin = radius + 20

    # Slow drift to prevent burn-in
    sx, sy = float(W // 2), float(H // 2)
    dx, dy = random.choice([-1, 1]) * 0.3, random.choice([-1, 1]) * 0.3

    while True:
        for event in pygame.event.get():
            if event.type in (pygame.QUIT, pygame.KEYDOWN,
                              pygame.MOUSEBUTTONDOWN, pygame.MOUSEMOTION):
                pygame.quit()
                sys.exit(0)

        sx += dx
        sy += dy
        if sx < margin or sx > W - margin:
            dx *= -1
        if sy < margin or sy > H - margin:
            dy *= -1

        cx, cy = int(sx), int(sy)
        screen.fill(BG)

        now = datetime.now()
        draw_clock(screen, cx, cy, radius, now)

        time_str = now.strftime("%H:%M")
        text = font.render(time_str, True, TEXT)
        screen.blit(text, (cx - text.get_width() // 2, cy + radius + 16))

        pygame.display.flip()
        clock.tick(60)


if __name__ == "__main__":
    main()
