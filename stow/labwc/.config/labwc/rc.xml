<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">

  <theme>
    <name>PiXonyx</name>
    <cornerRadius>0</cornerRadius>
    <keepBorder>yes</keepBorder>
    <font place="ActiveWindow">
      <name>Nunito Sans</name>
      <size>8</size>
      <weight>Light</weight>
      <slant>Normal</slant>
    </font>
    <font place="InactiveWindow">
      <name>Nunito Sans</name>
      <size>8</size>
      <weight>Light</weight>
      <slant>Normal</slant>
    </font>
    <font place="OnScreenDisplay">
      <name>Nunito Sans</name>
      <size>8</size>
      <weight>Light</weight>
      <slant>Normal</slant>
    </font>
    <dropShadows>yes</dropShadows>
    <titlebar>
      <layout>:iconify,max,close</layout>
    </titlebar>
  </theme>

  <keyboard>
    <numlock>off</numlock>
    <default/>

    <!-- Pi OS defaults: clear Alt+Arrow -->
    <keybind key="A-Left"/>
    <keybind key="A-Right"/>
    <keybind key="A-Up"/>
    <keybind key="A-Down"/>

    <!-- Halves (Pi OS default) -->
    <keybind key="C-A-Left">
      <action name="SnapToEdge" direction="left"/>
    </keybind>
    <keybind key="C-A-Right">
      <action name="SnapToEdge" direction="right"/>
    </keybind>
    <keybind key="C-A-Up">
      <action name="Maximize"/>
    </keybind>
    <keybind key="C-A-Down">
      <action name="UnMaximize"/>
    </keybind>

    <!-- Thirds: Super+1/2/3 -->
    <keybind key="W-1">
      <action name="SnapToRegion" region="third-left"/>
    </keybind>
    <keybind key="W-2">
      <action name="SnapToRegion" region="third-center"/>
    </keybind>
    <keybind key="W-3">
      <action name="SnapToRegion" region="third-right"/>
    </keybind>

    <!-- Two-thirds combos: Super+4/5/6 -->
    <keybind key="W-4">
      <action name="SnapToRegion" region="twothirds-left"/>
    </keybind>
    <keybind key="W-5">
      <action name="SnapToRegion" region="twothirds-right"/>
    </keybind>
    <keybind key="W-6">
      <action name="SnapToRegion" region="twothirds-center"/>
    </keybind>

    <!-- Maximize: Super+Up / Restore: Super+Down -->
    <keybind key="W-Up">
      <action name="Maximize"/>
    </keybind>
    <keybind key="W-Down">
      <action name="UnMaximize"/>
    </keybind>

    <!-- Pi OS system keys -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute">
        <command>wfpanelctl volumepulse volu</command>
      </action>
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute">
        <command>wfpanelctl volumepulse vold</command>
      </action>
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute">
        <command>wfpanelctl volumepulse mute</command>
      </action>
    </keybind>
    <keybind key="Super_L" onRelease="yes">
      <action name="Execute">
        <command>wfpanelctl smenu menu</command>
      </action>
    </keybind>
    <keybind key="C-A-w">
      <action name="Execute">
         <command>wfpanelctl netman menu</command>
      </action>
    </keybind>
    <keybind key="C-A-b">
      <action name="Execute">
         <command>wfpanelctl bluetooth menu</command>
      </action>
    </keybind>
    <keybind key="C-A-t">
      <action name="Execute">
         <command>lxterminal</command>
      </action>
    </keybind>
    <keybind key="C-A-space">
      <action name="Execute">
         <command>gui-pkinst orca reboot</command>
      </action>
    </keybind>
    <keybind key="C-A-Delete">
      <action name="Execute">
         <command>pishutdown</command>
      </action>
    </keybind>
    <keybind key="XF86PowerOff" onRelease="yes">
      <action name="Execute">
        <command>pwrkey</command>
      </action>
    </keybind>
    <keybind key="Print">
      <action name="Execute">
        <command>grim</command>
      </action>
    </keybind>
    <keybind key="C-A-m">
      <action name="ToggleMagnify"/>
    </keybind>
    <keybind key="C-A-l">
      <action name="Execute">
         <command>swaylock -p</command>
      </action>
    </keybind>
    <keybind key="A-F2">
      <action name="Execute">
        <command>wfpanelctl smenu run</command>
      </action>
    </keybind>
  </keyboard>

  <mouse>
    <default/>
    <context name="Title">
      <mousebind button="Right" action="Click">
      </mousebind>
    </context>
    <context name="WindowMenu">
      <mousebind button="Left" action="Click">
      </mousebind>
      <mousebind button="Right" action="Click">
      </mousebind>
    </context>
    <context name="All">
      <mousebind direction="W-Up" action="Scroll">
        <action name="ZoomIn"/>
      </mousebind>
      <mousebind direction="W-Down" action="Scroll">
        <action name="ZoomOut"/>
      </mousebind>
     </context>
  </mouse>

  <windowRules>
    <windowRule identifier="Kodi" serverDecoration="yes"/>
  </windowRules>

  <!-- Snap regions: thirds for 49" ultrawide (3840x1080) -->
  <regions>
    <!-- Single thirds -->
    <region name="third-left" x="0%" y="0%" width="33%" height="100%"/>
    <region name="third-center" x="33%" y="0%" width="34%" height="100%"/>
    <region name="third-right" x="67%" y="0%" width="33%" height="100%"/>
    <!-- Two-thirds combos -->
    <region name="twothirds-left" x="0%" y="0%" width="67%" height="100%"/>
    <region name="twothirds-right" x="33%" y="0%" width="67%" height="100%"/>
    <region name="twothirds-center" x="17%" y="0%" width="66%" height="100%"/>
  </regions>

  <snapping>
    <range>0</range>
    <topMaximize>no</topMaximize>
  </snapping>

  <magnifier>
    <width>-1</width>
    <height>-1</height>
    <initScale>2.0</initScale>
    <increment>0.2</increment>
    <useFilter>false</useFilter>
  </magnifier>

  <windowSwitcher show="yes" preview="yes" outlines="yes" allWorkspaces="no">
    <fields>
      <field content="icon" width="5%"/>
      <field content="title" width="95%"/>
    </fields>
  </windowSwitcher>

  <touch deviceName="10-0038 generic ft5x06 (79)" mapToOutput="DSI-1" mouseEmulation="yes"/>
  <touch deviceName="11-0038 generic ft5x06 (79)" mapToOutput="DSI-2" mouseEmulation="yes"/>
  <touch deviceName="6-0038 generic ft5x06 (79)" mapToOutput="DSI-1" mouseEmulation="yes"/>
  <touch deviceName="4-0038 generic ft5x06 (79)" mapToOutput="DSI-2" mouseEmulation="yes"/>
  <touch deviceName="10-0038 generic ft5x06 (00)" mapToOutput="DSI-1" mouseEmulation="yes"/>
  <touch deviceName="11-0038 generic ft5x06 (00)" mapToOutput="DSI-2" mouseEmulation="yes"/>
  <touch deviceName="6-0038 generic ft5x06 (00)" mapToOutput="DSI-1" mouseEmulation="yes"/>
  <touch deviceName="4-0038 generic ft5x06 (00)" mapToOutput="DSI-2" mouseEmulation="yes"/>
  <touch deviceName="10-005d Goodix Capacitive TouchScreen" mapToOutput="DSI-1" mouseEmulation="yes"/>
  <touch deviceName="11-005d Goodix Capacitive TouchScreen" mapToOutput="DSI-2" mouseEmulation="yes"/>
  <touch deviceName="6-005d Goodix Capacitive TouchScreen" mapToOutput="DSI-1" mouseEmulation="yes"/>
  <touch deviceName="4-005d Goodix Capacitive TouchScreen" mapToOutput="DSI-2" mouseEmulation="yes"/>

</openbox_config>
